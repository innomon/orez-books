{
  "compilerOptions": {
    "target": "es2020",
    "module": "esnext",
    "strict": true,
    "allowJs": true,
    "jsx": "preserve",
    "importHelpers": true,
    "moduleResolution": "node",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "types": ["node", "vite/client"],
    "baseUrl": ".",
    "paths": {
      "src/*": ["src/*"],
      "fyo/*": ["src/fyo/*"],
      "schemas/*": ["src/schemas/*"],
      "backend/*": ["src/backend/*"],
      "regional/*": ["src/regional/*"],
      "fixtures/*": ["src/fixtures/*"],
      "reports/*": ["src/reports/*"],
      "models/*": ["src/models/*"],
      "utils/*": ["src/utils/*"],
      "dummy/*": ["src/dummy/*"]
    },
    "lib": ["esnext", "dom", "dom.iterable", "scripthost"]
  },
  "ts-node": {
    "files": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.vue"
  ],
  "exclude": ["node_modules"]
}
